# Fetch @tailwindcss scope from npm (avoids JFrog proxy 404 for optional binaries like oxide-wasm32-wasi)
# Must appear before default registry so scope is used when jf ca runs npm
@tailwindcss:registry=https://registry.npmjs.org/

json = false
registry = https://solenglatest.jfrog.io/artifactory/api/npm/rsa-demo-npm
